{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "R2D: Build Debug",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [
                "debug",
                "all"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "R2D: Build Release",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [
                "release",
                "all"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "R2D: Build Debug Sandbox",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [
                "debug",
                "r2d_sandbox"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "R2D: Build Debug Collect",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [
                "debug",
                "r2d_collect"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "R2D: Configure CMake",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [
                "configure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "R2D: Open Build GUI",
            "type": "shell",
            "command": "${workspaceFolder}\\build_gui.bat",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
